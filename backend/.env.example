# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Ma'lumotlar bazasi ───────────────────────────────
MONGODB_URI=mongodb://localhost:27017/parkent-express

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRE=30d

# ── Telegram Botlar ──────────────────────────────────
CUSTOMER_BOT_TOKEN=your-customer-bot-token
DRIVER_BOT_TOKEN=your-driver-bot-token
VENDOR_BOT_TOKEN=your-vendor-bot-token

# ── Redis (ixtiyoriy — bo'lmasa xotirada saqlaydi) ───
# REDIS_URL=redis://localhost:6379

# ── Frontend URL (CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Loglash ──────────────────────────────────────────
LOG_LEVEL=info

# ── Karta to'lovi ────────────────────────────────────
CARD_PAYMENT_ENABLED=true
RECEIPT_UPLOAD_MAX_SIZE=5242880

# ── API URL (botlar uchun) ────────────────────────────
API_URL=http://localhost:5000/api/v1
